# ──────────────────────────────────────────────────────────────
# JobPilot — Variables de Entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env a git.
# ──────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL=postgresql://jobpilot:jobpilot@localhost:5432/jobpilot

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Modo mock: true = no llama a Gemini real (para desarrollo)
GEMINI_MOCK_MODE=true

# ── Portales — Credenciales ───────────────────────────────────
LINKEDIN_EMAIL=tu@email.com
LINKEDIN_PASSWORD=tu_password

BUMERAN_EMAIL=tu@email.com
BUMERAN_PASSWORD=tu_password

LABORUM_EMAIL=tu@email.com
LABORUM_PASSWORD=tu_password

INDEED_EMAIL=tu@email.com
INDEED_PASSWORD=tu_password

SENCE_RUT=12345678-9
SENCE_PASSWORD=tu_clave_sence

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Configuración general ─────────────────────────────────────
# Directorio raíz del proyecto (se autocompleta si no se define)
PROJECT_ROOT=

# Entorno: development | production
ENVIRONMENT=development
